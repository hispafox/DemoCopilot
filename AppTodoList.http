@AppTodoList_HostAddress = http://localhost:5104

### ===========================
### TAREAS  /api/tareas
### ===========================

### Listar todas las tareas
GET {{AppTodoList_HostAddress}}/api/tareas
Accept: application/json

###

### Listar tareas por categoría
GET {{AppTodoList_HostAddress}}/api/tareas?categoriaId=1
Accept: application/json

###

### Obtener tarea por ID
GET {{AppTodoList_HostAddress}}/api/tareas/1
Accept: application/json

###

### Crear tarea
POST {{AppTodoList_HostAddress}}/api/tareas
Content-Type: application/json

{
  "title": "Nueva tarea de ejemplo",
  "esRepetitiva": false,
  "recurrencia": null,
  "plantillaId": null,
  "usuarioAsignadoId": null,
  "categoriaId": null
}

###

### Actualizar tarea
PUT {{AppTodoList_HostAddress}}/api/tareas/1
Content-Type: application/json

{
  "title": "Tarea actualizada",
  "isCompleted": false,
  "esRepetitiva": false,
  "recurrencia": null,,
  "categoriaId": null
  "usuarioAsignadoId": null
}

###

### Eliminar tarea
DELETE {{AppTodoList_HostAddress}}/api/tareas/1

###

### Completar tarea
POST {{AppTodoList_HostAddress}}/api/tareas/1/completar

###

### ===========================
### PLANTILLAS  /api/plantillas
### ===========================

### Listar todas las plantillas
GET {{AppTodoList_HostAddress}}/api/plantillas
Accept: application/json

###

### Obtener plantilla por ID
GET {{AppTodoList_HostAddress}}/api/plantillas/1
Accept: application/json

###

### Crear plantilla
POST {{AppTodoList_HostAddress}}/api/plantillas
Content-Type: application/json

{
  "titulo": "Plantilla de ejemplo",
  "esRepetitiva": false,
  "recurrencia": null
}

###

### Actualizar plantilla
PUT {{AppTodoList_HostAddress}}/api/plantillas/1
Content-Type: application/json

{
  "titulo": "Plantilla actualizada",
  "esRepetitiva": true,
  "recurrencia": 1
}

###

### Eliminar plantilla
DELETE {{AppTodoList_HostAddress}}/api/plantillas/1

###

### Instanciar tarea desde plantilla
POST {{AppTodoList_HostAddress}}/api/plantillas/1/instanciar

###

### =======================================
### USUARIOS ASIGNADOS  /api/usuariosasignados
### =======================================

### Listar todos los usuarios asignados
GET {{AppTodoList_HostAddress}}/api/usuariosasignados
Accept: application/json

###

### Obtener usuario asignado por ID
GET {{AppTodoList_HostAddress}}/api/usuariosasignados/1
Accept: application/json

###

### Crear usuario asignado
POST {{AppTodoList_HostAddress}}/api/usuariosasignados
Content-Type: application/json

{
  "nombre": "Pedro García",
  "email": "pedro@example.com"
}

###

### Actualizar usuario asignado
PUT {{AppTodoList_HostAddress}}/api/usuariosasignados/1
Content-Type: application/json

{
  "nombre": "Pedro García Actualizado",
  "email": "pedro.nuevo@example.com"
}

###

### Eliminar usuario asignado
DELETE {{AppTodoList_HostAddress}}/api/usuariosasignados/1


### ===========================
### CATEGORÍAS  /api/categorias
### ===========================

### Listar todas las categorías
GET {{AppTodoList_HostAddress}}/api/categorias
Accept: application/json

###

### Obtener categoría por ID
GET {{AppTodoList_HostAddress}}/api/categorias/1
Accept: application/json

###

### Crear categoría
POST {{AppTodoList_HostAddress}}/api/categorias
Content-Type: application/json

{
  "nombre": "Trabajo",
  "color": "#FF5733"
}

###

### Actualizar categoría
PUT {{AppTodoList_HostAddress}}/api/categorias/1
Content-Type: application/json

{
  "nombre": "Personal",
  "color": "#33C4FF"
}

###

### Eliminar categoría
DELETE {{AppTodoList_HostAddress}}/api/categorias/1

